# Port Configuration
PORT=5000
NODE_ENV=development

# Database Connection
DATABASE_URL="postgresql://username:password@localhost:5432/dbname?schema=public"

# Authentication Secrets
JWT_SECRET="your_jwt_access_secret_key"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key"

# Payment Gateways (Razorpay)
RAZORPAY_KEY_ID="rzp_test_xxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# Notifications Configuration
SMS_OTP_PROVIDER="mock" # "mock" or "real"
EMAIL_PROVIDER="mock" # "mock" or "nodemailer"
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_HOST="smtp.yourdomain.com"
EMAIL_PORT=587
EMAIL_USER="your_smtp_username"
EMAIL_PASS="your_smtp_password"

# Company Details for GST Invoices
COMPANY_NAME="SkillForge Academy Private Limited"
COMPANY_GSTIN="GST_NUMBER_HERE"
COMPANY_STATE="StateName"
COMPANY_ADDRESS="Company Physical Address"
GST_RATE_PERCENT=18
